# 백엔드 환경변수 예시 — 복사해서 .env 로 사용하세요.

# 서버
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# 데이터베이스 (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/comchin?schema=public"

# 인증
JWT_SECRET=change-this-to-a-long-random-secret

# (선택) 구글 로그인: 구글 클라우드 콘솔 OAuth 클라이언트 ID (프론트와 동일 값)
# 없으면 구글 로그인 비활성화. 이메일 회원가입/로그인은 그대로 동작.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# AI (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key

# 네이버 쇼핑 검색 API (부품 이미지/가격 자동 채우기 — scripts/enrich-from-naver.js)
# https://developers.naver.com 에서 앱 등록 후 "검색" API 추가
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
